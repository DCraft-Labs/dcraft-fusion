# ─────────────────────────────────────────────────────────────────────────────
# Fusion CDC Engine — Frontend
# Multi-stage: node builder → nginx runtime
# Target: nginx:alpine | Port: 80
# Build arg: VITE_API_BASE_URL (set in CI/CD)
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Cache deps separately from source
COPY frontend/package.json frontend/package-lock.json* frontend/yarn.lock* ./
RUN npm install --frozen-lockfile 2>/dev/null || npm install

COPY frontend/ .

ARG VITE_API_BASE_URL=https://api.dcraftfusion.dev
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

RUN npm run build

# ── Stage 2: nginx runtime ────────────────────────────────────────────────────
# Use unprivileged image — runs as non-root (uid 101) on port 8080,
# no writable /var/cache/nginx issue in restricted K8s security contexts.
FROM nginxinc/nginx-unprivileged:alpine

# Switch to root for setup, then drop back to nginx user
USER root

# Copy built assets (overwrites default index.html)
COPY --from=builder /app/dist /usr/share/nginx/html

# nginx config:
#   - Serve SPA (all routes → index.html)
#   - Proxy /api/ → control-plane K8s service (avoids cross-origin issues)
#   - Port 8080 (unprivileged)
RUN printf 'server {\n\
    listen 8080;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    location /api/ {\n\
        proxy_pass http://fusion-control-plane-svc:8000/api/;\n\
        proxy_set_header Host $host;\n\
        proxy_set_header X-Real-IP $remote_addr;\n\
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\n\
        proxy_set_header X-Forwarded-Proto $scheme;\n\
    }\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
    }\n\
    location /health {\n\
        return 200 "ok";\n\
        add_header Content-Type text/plain;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf && \
    chown -R nginx:nginx /usr/share/nginx/html /etc/nginx/conf.d/default.conf

USER nginx

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
