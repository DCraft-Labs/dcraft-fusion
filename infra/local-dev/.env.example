# Copy to .env for local overrides (never commit .env).
POSTGRES_PASSWORD=CHANGE_ME
FUSION_AUTH_MODE=password
FUSION_SEED_FOUNDER_EMAIL=founder@dcraftlabs.com
FUSION_SEED_FOUNDER_PASSWORD=CHANGE_ME
FUSION_SEED_SUPERADMIN_EMAIL=superadmin@dcraftlabs.com
FUSION_SEED_SUPERADMIN_PASSWORD=CHANGE_ME

# CDC profile (docker-compose.cdc.yml --profile cdc)
# Uses official GHCR images only — no local engine build.
CDC_POSTGRES_PASSWORD=CHANGE_ME
CDC_SECRET_KEY=CHANGE_ME_SECRET_KEY
CDC_ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_32C
CDC_WORKER_TOKEN_SECRET=CHANGE_ME_WORKER_SECRET
CDC_WORKER_TOKEN=CHANGE_ME_WORKER_TOKEN
